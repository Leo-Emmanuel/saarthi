# Copy this file to .env and fill in your values
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/saarthi?retryWrites=true&w=majority
# REQUIRED — generate a strong random key e.g: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_strong_random_secret_key_here

# Set to true ONLY for local development. Never set true in production.
FLASK_DEBUG=false

# Comma-separated list of allowed frontend origins
# Development: http://localhost:5173
# Production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiter storage. Use memory:// for development.
# Use redis://localhost:6379/0 for production multi-worker deployments.
RATELIMIT_STORAGE_URI=memory://

# Set true in production when serving over HTTPS.
JWT_COOKIE_SECURE=true
